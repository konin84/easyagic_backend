{
  "info": {
    "name": "EasyAgric API",
    "description": "Agricultural advisory app — soil analysis, weather, crop recommendations.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "https://easyagic-backend.onrender.com",
      "type": "string"
    },
    {
      "key": "access_token",
      "value": "",
      "type": "string",
      "description": "JWT access token — populated automatically after Login or Register"
    },
    {
      "key": "refresh_token",
      "value": "",
      "type": "string",
      "description": "JWT refresh token — populated automatically after Login or Register"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "List Languages",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/auth/languages/",
            "description": "Returns all supported language codes and names. No authentication required. The Flutter app should call this on first launch to populate the language picker."
          }
        },
        {
          "name": "Register Farmer",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const body = pm.response.json();",
                  "    pm.collectionVariables.set('access_token', body.access);",
                  "    pm.collectionVariables.set('refresh_token', body.refresh);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/api/auth/register/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"farmer@example.com\",\n  \"phone\": \"+1234567890\",\n  \"farm_name\": \"Green Valley Farm\",\n  \"language\": \"en\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Creates a farmer account. No password — a secure password is auto-generated and emailed to the farmer. Returns JWT access and refresh tokens. Supported language codes: en, fr, sw, ha, yo, ig, am, zu, xh, tw, wo, ln, sn, dyu, bci, bm, ff. Defaults to 'en' if omitted."
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const body = pm.response.json();",
                  "    pm.collectionVariables.set('access_token', body.access);",
                  "    pm.collectionVariables.set('refresh_token', body.refresh);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/api/auth/login/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@easyagric.com\",\n  \"password\": \"admin1234\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Authenticates any user (farmer, app manager, or admin). Returns JWT access token (30 min) and refresh token (7 days)."
          }
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const body = pm.response.json();",
                  "    pm.collectionVariables.set('access_token', body.access);",
                  "    pm.collectionVariables.set('refresh_token', body.refresh);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/api/auth/token/refresh/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh\": \"{{refresh_token}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Exchange a refresh token for a new access token. The old refresh token is blacklisted and a new one is returned (token rotation). Call this when the access token expires."
          }
        },
        {
          "name": "Register App Manager (Admin only)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/api/auth/register/app-manager/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"manager@easyagric.com\",\n  \"phone\": \"+1234567890\",\n  \"first_name\": \"John\",\n  \"last_name\": \"Doe\",\n  \"language\": \"en\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Creates an App Manager account. Requires superadmin authentication. A secure password is auto-generated and emailed. App managers can access all endpoints without GPS coordinates."
          }
        },
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": "{{base_url}}/api/auth/me/",
            "description": "Returns the authenticated user's profile: id, email, role, phone, farm_name, date_joined."
          }
        },
        {
          "name": "Update My Profile",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/api/auth/me/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"+0987654321\",\n  \"farm_name\": \"Blue Horizon Farm\",\n  \"language\": \"fr\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Partially updates the authenticated user's profile. All fields are optional."
          }
        },
        {
          "name": "Change Password",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const body = pm.response.json();",
                  "    pm.collectionVariables.set('access_token', body.access);",
                  "    pm.collectionVariables.set('refresh_token', body.refresh);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/api/auth/password/change/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"current_password\": \"oldpassword123\",\n  \"new_password\": \"newpassword456\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Changes the password for the authenticated user. Requires the current password for verification. Returns fresh JWT tokens so the user stays logged in after the change."
          }
        },
        {
          "name": "Request Password Reset (OTP)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/api/auth/password-reset/request/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"farmer@example.com\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Sends a 6-digit OTP to the email. Valid for 10 minutes. Always returns the same message (prevents user enumeration)."
          }
        },
        {
          "name": "Verify OTP & Set New Password",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const body = pm.response.json();",
                  "    pm.collectionVariables.set('access_token', body.access);",
                  "    pm.collectionVariables.set('refresh_token', body.refresh);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/api/auth/password-reset/verify/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"farmer@example.com\",\n  \"otp\": \"123456\",\n  \"new_password\": \"newpassword123\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Verifies the OTP and sets a new password. Returns fresh JWT tokens."
          }
        }
      ]
    },
    {
      "name": "Weather",
      "item": [
        {
          "name": "Get Agricultural Weather",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/weather/?lat=5.35&lon=-4.0",
              "host": ["{{base_url}}"],
              "path": ["api", "weather", ""],
              "query": [
                { "key": "lat", "value": "5.35", "description": "GPS latitude (captured by mobile app at the farm)" },
                { "key": "lon", "value": "-4.0", "description": "GPS longitude (captured by mobile app at the farm)" }
              ]
            },
            "description": "Returns current weather, soil temperature at 0/6/18/54 cm depth, soil moisture, and 7-day forecast from Open-Meteo. Requires authentication. lat and lon are required for farmers; admins and app managers receive a prompt if omitted."
          }
        }
      ]
    },
    {
      "name": "Soil",
      "item": [
        {
          "name": "Analyze Soil Photo",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": "{{base_url}}/api/soil/analyze/",
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "image",
                  "type": "file",
                  "src": "",
                  "description": "Photo of the soil taken by the farmer at the farm"
                }
              ]
            },
            "description": "Upload a soil photo. Gemini Vision analyses it and returns soil type, color, texture, pH estimate, fertility, visible issues, and amendment recommendations."
          }
        }
      ]
    },
    {
      "name": "Crops",
      "item": [
        {
          "name": "Get Crop Recommendations",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/crops/recommend/?soil_type=Loam&temp=25",
              "host": ["{{base_url}}"],
              "path": ["api", "crops", "recommend", ""],
              "query": [
                {
                  "key": "soil_type",
                  "value": "Loam",
                  "description": "Clay | Sandy | Loam | Silt | Laterite | Black Cotton | Alluvial"
                },
                {
                  "key": "temp",
                  "value": "25",
                  "description": "Current air temperature in °C (optional — improves ranking)"
                }
              ]
            },
            "description": "Returns crops ranked by suitability for the given soil type and current temperature. Factors in the current month for seasonal filtering."
          }
        }
      ]
    },
    {
      "name": "Advisor",
      "item": [
        {
          "name": "Get Full Farm Advice",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": "{{base_url}}/api/advisor/",
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "image",
                  "type": "file",
                  "src": "",
                  "description": "Photo of the soil taken at the farm"
                },
                {
                  "key": "lat",
                  "value": "5.35",
                  "type": "text",
                  "description": "GPS latitude — captured automatically by the mobile app at the farm"
                },
                {
                  "key": "lon",
                  "value": "-4.0",
                  "type": "text",
                  "description": "GPS longitude — captured automatically by the mobile app at the farm"
                }
              ]
            },
            "description": "Main mobile endpoint. Farmer takes a soil photo at their farm — the mobile app captures GPS automatically. Returns soil analysis, weather data, and crop recommendations in one response. Report is also emailed to the farmer and a push notification is sent. Admins and app managers can omit lat/lon — weather will be skipped but soil analysis still runs."
          }
        }
      ]
    },
    {
      "name": "History",
      "item": [
        {
          "name": "My Analysis History",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": "{{base_url}}/api/history/",
            "description": "Returns all analysis records for the authenticated farmer, ordered by most recent first."
          }
        },
        {
          "name": "Analysis Record Detail",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": "{{base_url}}/api/history/1/",
            "description": "Returns full detail of a single analysis record. Replace 1 with the actual record id."
          }
        }
      ]
    },
    {
      "name": "Dashboard",
      "item": [
        {
          "name": "Stats",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": "{{base_url}}/api/dashboard/stats/",
            "description": "Returns aggregate stats: total farmers, new farmers (7/30 days), total analyses, analyses (7/30 days). Requires admin or app manager role."
          }
        },
        {
          "name": "Farmer List",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": "{{base_url}}/api/dashboard/farmers/",
            "description": "Returns all farmers with their analysis count, ordered by most recently joined. Requires admin or app manager role."
          }
        },
        {
          "name": "Farmer Detail",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": "{{base_url}}/api/dashboard/farmers/1/",
            "description": "Returns a farmer's profile and their 10 most recent analyses. Replace 1 with the actual farmer id. Requires admin or app manager role."
          }
        }
      ]
    },
    {
      "name": "Notifications",
      "item": [
        {
          "name": "Register Device Token",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/api/notifications/register/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"FCM_DEVICE_TOKEN_HERE\",\n  \"platform\": \"android\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Registers the device's FCM token for push notifications. Call this on app launch after the user logs in. platform must be 'android' or 'ios'."
          }
        },
        {
          "name": "Unregister Device Token",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/api/notifications/unregister/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"FCM_DEVICE_TOKEN_HERE\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Removes the device token. Call this on logout so the user no longer receives push notifications on this device."
          }
        }
      ]
    }
  ]
}
